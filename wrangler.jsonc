// 2026-05-24 Cloudflare Workers + 静态资源部署配置
// 不走 opennextjs-cloudflare（动态 SSR adapter，对 Next 14 不兼容），
// 直接把 next build --output export 产出的 ./out 目录当 static assets serve
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "clairesparlor",
  "compatibility_date": "2024-12-30",
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page"
  }
}
